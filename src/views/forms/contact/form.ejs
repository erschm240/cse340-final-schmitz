<%- include('../../partials/header') %>
<main>
    <h1>Contact a Site Member</h1>
    <p>Do you have questions about a tutorial or our site? Have feedback to give? You can send a message to our team addressed to the site owner or one of our instructors and we will respond as soon as possible.</p>

    <form method="POST" action="/contact" class="contact-form">
        <div class="form-group">
            <label for="recipient">Recipient</label>
            <input type="text" id="recipient" name="recipient" placeholder="Who is this message for?" minlength="2" required>
        </div>
        <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" placeholder="What is this message about?" minlength="2" required>
        </div>
        <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="6" placeholder="What would you like to say?" minlength="10" required></textarea>
        </div>

        <button type="submit" class="submit-button">Send Message</button>
    </form>
</main>
<%- include('../../partials/footer') %>