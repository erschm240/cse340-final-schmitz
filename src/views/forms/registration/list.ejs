<%- include('../../partials/header') %>
<main>
    <h1><%= title %></h1>
    <% if (users && users.length > 0) { %>
        <div class="users-list">
            <% users.forEach(listUser => { %>
                <%
                    // Calculate permissions for this user card
                    // 'user' variable contains the current logged-in user
                    // 'listUser' is the user from the users array we're currently rendering
                    const currentUser = typeof isLoggedIn !== 'undefined' && isLoggedIn ? user : null;
                    const canEdit = currentUser && (currentUser.id === listUser.id || currentUser.roleName === 'admin');
                    const canDelete = currentUser &&currentUser.roleName === 'admin' && currentUser.id !== listUser.id;
                %>
                <div class="user-card">
                        <h2><%= listUser.name %></h2>

                    <div class="user-details">
                        <div class="detail-item">
                            <div class="label">Username:</div>
                            <div class="value"><%= listUser.username %></div>
                        </div>

                        <div class="detail-item">
                            <div class="label">Email:</div>
                            <div class="value"><%= listUser.email %></div>
                        </div>

                        <div class="detail-item">
                            <div class="label">Register Date:</div>
                            <div class="value"><%= new Date(listUser.createdAt).toLocaleDateString() %></div>
                        </div>
                    </div>

                    <% if (canEdit || canDelete) { %>
                        <div class="user-actions">
                            <% if (canEdit) { %>
                                <a href="/register/<%= listUser.userId %>/edit">Edit</a>
                            <% } %>

                            <% if (canDelete) { %>
                                <form method="post" action="/register/<%= listUser.id %>/delete" style="display: inline;">
                                    <button type="submit" onclick="return confirm('Are you sure you want to delete this account?')">Delete</button>
                                </form>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <p class="no-users">No users registered yet.</p>
    <% } %>
</main>
<%- include('../../partials/footer') %>